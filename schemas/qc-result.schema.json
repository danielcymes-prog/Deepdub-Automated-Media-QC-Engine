{
  "$defs": {
    "AISummary": {
      "additionalProperties": false,
      "description": "AI-generated commentary, stored strictly apart from canonical findings.\n\nSchema reserved in M1; populated only in Phase 9 (ADR-001). The presence\nor absence of this block must never change any canonical field.",
      "properties": {
        "content": {
          "title": "Content",
          "type": "string"
        },
        "generated_at": {
          "title": "Generated At",
          "type": "string"
        },
        "model": {
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "prompt_version": {
          "title": "Prompt Version",
          "type": "string"
        },
        "provider": {
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        }
      },
      "required": [
        "provider",
        "model",
        "prompt_version",
        "generated_at",
        "content"
      ],
      "title": "AISummary",
      "type": "object"
    },
    "ActualValue": {
      "additionalProperties": false,
      "description": "The measured value a rule was evaluated against.",
      "properties": {
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "value"
      ],
      "title": "ActualValue",
      "type": "object"
    },
    "ArtifactPaths": {
      "additionalProperties": false,
      "description": "Relative paths of rendered artifacts inside the job output directory.",
      "properties": {
        "evidence_directory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Directory"
        },
        "html_report": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Html Report"
        },
        "pdf_report": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pdf Report"
        },
        "raw_directory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Directory"
        }
      },
      "title": "ArtifactPaths",
      "type": "object"
    },
    "Asset": {
      "additionalProperties": false,
      "description": "The media file a QC job analyzed. `sha256` makes results traceable to exact bytes.",
      "properties": {
        "duration_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Seconds"
        },
        "file_size_bytes": {
          "minimum": 0,
          "title": "File Size Bytes",
          "type": "integer"
        },
        "filename": {
          "minLength": 1,
          "title": "Filename",
          "type": "string"
        },
        "input_path": {
          "minLength": 1,
          "title": "Input Path",
          "type": "string"
        },
        "sha256": {
          "minLength": 1,
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "input_path",
        "filename",
        "file_size_bytes",
        "sha256"
      ],
      "title": "Asset",
      "type": "object"
    },
    "Category": {
      "enum": [
        "file",
        "container",
        "video",
        "audio",
        "subtitle",
        "metadata",
        "deepdub"
      ],
      "title": "Category",
      "type": "string"
    },
    "Environment": {
      "additionalProperties": false,
      "description": "Execution environment fingerprint (ADR-008, DATA_MODEL_REVIEW item 3).",
      "properties": {
        "docker_image": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Docker Image"
        },
        "ffmpeg_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ffmpeg Version"
        },
        "ffprobe_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ffprobe Version"
        },
        "platform": {
          "minLength": 1,
          "title": "Platform",
          "type": "string"
        },
        "python_version": {
          "minLength": 1,
          "title": "Python Version",
          "type": "string"
        }
      },
      "required": [
        "python_version",
        "platform"
      ],
      "title": "Environment",
      "type": "object"
    },
    "Evidence": {
      "additionalProperties": false,
      "description": "One evidence artifact (thumbnail, waveform, clip, or raw tool output).",
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "end_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Seconds"
        },
        "evidence_id": {
          "format": "uuid",
          "title": "Evidence Id",
          "type": "string"
        },
        "finding_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finding Id"
        },
        "generated_by": {
          "minLength": 1,
          "title": "Generated By",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "start_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Seconds"
        },
        "type": {
          "$ref": "#/$defs/EvidenceType"
        }
      },
      "required": [
        "evidence_id",
        "type",
        "path",
        "generated_by"
      ],
      "title": "Evidence",
      "type": "object"
    },
    "EvidenceType": {
      "enum": [
        "thumbnail",
        "waveform",
        "clip",
        "raw"
      ],
      "title": "EvidenceType",
      "type": "string"
    },
    "ExpectedApprox": {
      "additionalProperties": false,
      "description": "A target value with tolerance (approximately_equals).",
      "properties": {
        "tolerance": {
          "exclusiveMinimum": 0,
          "title": "Tolerance",
          "type": "number"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "value",
        "tolerance"
      ],
      "title": "ExpectedApprox",
      "type": "object"
    },
    "ExpectedNothing": {
      "additionalProperties": false,
      "description": "No payload (exists, not_exists).",
      "properties": {
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "title": "ExpectedNothing",
      "type": "object"
    },
    "ExpectedPattern": {
      "additionalProperties": false,
      "description": "A regular expression the actual value must match (regex).",
      "properties": {
        "pattern": {
          "minLength": 1,
          "title": "Pattern",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "pattern"
      ],
      "title": "ExpectedPattern",
      "type": "object"
    },
    "ExpectedRange": {
      "additionalProperties": false,
      "description": "An inclusive numeric range (between).",
      "properties": {
        "max": {
          "title": "Max",
          "type": "number"
        },
        "min": {
          "title": "Min",
          "type": "number"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "min",
        "max"
      ],
      "title": "ExpectedRange",
      "type": "object"
    },
    "ExpectedValue": {
      "additionalProperties": false,
      "description": "A single comparison value (equals, ordering, contains, count_*).",
      "properties": {
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "title": "Value"
        }
      },
      "required": [
        "value"
      ],
      "title": "ExpectedValue",
      "type": "object"
    },
    "ExpectedValues": {
      "additionalProperties": false,
      "description": "A set of allowed/forbidden values (in, not_in, contains_all).",
      "properties": {
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "values": {
          "items": {},
          "minItems": 1,
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "values"
      ],
      "title": "ExpectedValues",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "description": "Outcome of one rule evaluation.\n\nCanonical `message` text is produced from deterministic templates.\nAI-generated explanations are never stored here (ADR-001); they belong to\nthe separate `ai_summary` structure on the report.",
      "properties": {
        "actual": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActualValue"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "blocking": {
          "title": "Blocking",
          "type": "boolean"
        },
        "category": {
          "$ref": "#/$defs/Category"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "display_name": {
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "end_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Seconds"
        },
        "end_timecode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Timecode"
        },
        "evidence_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "expected": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExpectedValue"
            },
            {
              "$ref": "#/$defs/ExpectedValues"
            },
            {
              "$ref": "#/$defs/ExpectedRange"
            },
            {
              "$ref": "#/$defs/ExpectedApprox"
            },
            {
              "$ref": "#/$defs/ExpectedPattern"
            },
            {
              "$ref": "#/$defs/ExpectedNothing"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected"
        },
        "finding_id": {
          "format": "uuid",
          "title": "Finding Id",
          "type": "string"
        },
        "job_id": {
          "format": "uuid",
          "title": "Job Id",
          "type": "string"
        },
        "measurement_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "title": "Measurement Ids",
          "type": "array"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "parameter_id": {
          "minLength": 1,
          "title": "Parameter Id",
          "type": "string"
        },
        "rule_id": {
          "minLength": 1,
          "title": "Rule Id",
          "type": "string"
        },
        "rule_version": {
          "title": "Rule Version",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "start_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Seconds"
        },
        "start_timecode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Timecode"
        },
        "status": {
          "$ref": "#/$defs/QCStatus"
        },
        "stream_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stream Index"
        },
        "suggested_action": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Suggested Action"
        }
      },
      "required": [
        "finding_id",
        "job_id",
        "rule_id",
        "parameter_id",
        "category",
        "display_name",
        "status",
        "severity",
        "message",
        "blocking",
        "rule_version"
      ],
      "title": "Finding",
      "type": "object"
    },
    "JobStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "JobStatus",
      "type": "string"
    },
    "JsonValue": {},
    "Measurement": {
      "additionalProperties": false,
      "description": "One normalized value extracted from a media asset by a detector.\n\nDeterminism (ADR-008): `measurement_id` is a content-derived UUIDv5\n(see deepdub_qc.utils.ids). `created_at` is a declared volatile field.",
      "properties": {
        "category": {
          "$ref": "#/$defs/Category"
        },
        "confidence": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "detector_id": {
          "minLength": 1,
          "title": "Detector Id",
          "type": "string"
        },
        "detector_version": {
          "title": "Detector Version",
          "type": "string"
        },
        "end_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Seconds"
        },
        "end_timecode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Timecode"
        },
        "job_id": {
          "format": "uuid",
          "title": "Job Id",
          "type": "string"
        },
        "measurement_id": {
          "format": "uuid",
          "title": "Measurement Id",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Metadata",
          "type": "object"
        },
        "parameter_id": {
          "minLength": 1,
          "title": "Parameter Id",
          "type": "string"
        },
        "raw_artifact_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Artifact Path"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "start_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Seconds"
        },
        "start_timecode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Timecode"
        },
        "stream_index": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stream Index"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "$ref": "#/$defs/JsonValue"
        }
      },
      "required": [
        "measurement_id",
        "job_id",
        "detector_id",
        "detector_version",
        "parameter_id",
        "category",
        "value"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "PresetRef": {
      "additionalProperties": false,
      "description": "Reference to the exact preset a job used.\n\n`sha256` is the hash of the preset file bytes: `preset_version` alone is\ninsufficient because draft presets are mutable (DATA_MODEL_REVIEW item 4).",
      "properties": {
        "client": {
          "minLength": 1,
          "title": "Client",
          "type": "string"
        },
        "content_type": {
          "minLength": 1,
          "title": "Content Type",
          "type": "string"
        },
        "preset_id": {
          "minLength": 1,
          "title": "Preset Id",
          "type": "string"
        },
        "preset_version": {
          "title": "Preset Version",
          "type": "string"
        },
        "sha256": {
          "minLength": 1,
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "preset_id",
        "preset_version",
        "client",
        "content_type",
        "sha256"
      ],
      "title": "PresetRef",
      "type": "object"
    },
    "QCJob": {
      "additionalProperties": false,
      "description": "Execution record of a QC job.\n\nAll timestamp/duration fields are declared volatile for determinism\ncomparisons (ADR-008); `job_id` is the only random identifier in the system.",
      "properties": {
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "duration_seconds": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration Seconds"
        },
        "job_id": {
          "format": "uuid",
          "title": "Job Id",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "status": {
          "$ref": "#/$defs/JobStatus"
        },
        "tool_version": {
          "title": "Tool Version",
          "type": "string"
        }
      },
      "required": [
        "job_id",
        "status",
        "tool_version"
      ],
      "title": "QCJob",
      "type": "object"
    },
    "QCStatus": {
      "description": "Outcome of evaluating one rule, or of a whole job.\n\nSemantics (see docs/DATA_MODEL_REVIEW.md item 7):\n    NOT_APPLICABLE: rule disabled, or its stream selector matches nothing\n        by design.\n    SKIPPED: a required measurement was expected but unavailable\n        (e.g. upstream detector did not run). A SKIPPED enabled blocking\n        rule escalates the job to ERROR - the tool must not pass a file\n        it failed to inspect.",
      "enum": [
        "PASS",
        "WARNING",
        "FAIL",
        "ERROR",
        "SKIPPED",
        "NOT_APPLICABLE"
      ],
      "title": "QCStatus",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "Summary": {
      "additionalProperties": false,
      "description": "Aggregated counts and the overall verdict (handoff section 17.3).",
      "properties": {
        "blocking_failures": {
          "minimum": 0,
          "title": "Blocking Failures",
          "type": "integer"
        },
        "errors": {
          "minimum": 0,
          "title": "Errors",
          "type": "integer"
        },
        "failed": {
          "minimum": 0,
          "title": "Failed",
          "type": "integer"
        },
        "not_applicable": {
          "minimum": 0,
          "title": "Not Applicable",
          "type": "integer"
        },
        "overall_status": {
          "$ref": "#/$defs/QCStatus"
        },
        "passed": {
          "minimum": 0,
          "title": "Passed",
          "type": "integer"
        },
        "skipped": {
          "minimum": 0,
          "title": "Skipped",
          "type": "integer"
        },
        "total_checks": {
          "minimum": 0,
          "title": "Total Checks",
          "type": "integer"
        },
        "warnings": {
          "minimum": 0,
          "title": "Warnings",
          "type": "integer"
        }
      },
      "required": [
        "overall_status",
        "total_checks",
