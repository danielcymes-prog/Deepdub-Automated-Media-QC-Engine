{
  "$defs": {
    "JobStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled"
      ],
      "title": "JobStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Execution record of a QC job.\n\nAll timestamp/duration fields are declared volatile for determinism\ncomparisons (ADR-008); `job_id` is the only random identifier in the system.",
  "properties": {
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "duration_seconds": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Seconds"
    },
    "job_id": {
      "format": "uuid",
      "title": "Job Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "$ref": "#/$defs/JobStatus"
    },
    "tool_version": {
      "title": "Tool Version",
      "type": "string"
    }
  },
  "required": [
    "job_id",
    "status",
    "tool_version"
  ],
  "title": "QCJob",
  "type": "object"
}
