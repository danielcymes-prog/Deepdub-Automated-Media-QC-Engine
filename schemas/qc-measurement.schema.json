{
  "$defs": {
    "Category": {
      "enum": [
        "file",
        "container",
        "video",
        "audio",
        "subtitle",
        "metadata",
        "deepdub"
      ],
      "title": "Category",
      "type": "string"
    },
    "JsonValue": {}
  },
  "additionalProperties": false,
  "description": "One normalized value extracted from a media asset by a detector.\n\nDeterminism (ADR-008): `measurement_id` is a content-derived UUIDv5\n(see deepdub_qc.utils.ids). `created_at` is a declared volatile field.",
